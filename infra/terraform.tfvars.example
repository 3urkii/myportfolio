# Copy to terraform.tfvars (gitignored) and fill in real values.
acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/00000000-0000-0000-0000-000000000000"
github_repo         = "your-github-username/berkepro-redesign"
notification_email  = "you@example.com"

# Optional — all have defaults; override only if a bucket name is taken:
# domain_name      = "berke.pro"
# site_bucket_name = "berkepro-site"
# logs_bucket_name = "berkepro-logs"
